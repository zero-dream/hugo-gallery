{
  "editor.tabSize": 2,
  "files.eol": "\n",
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*index.md": "*.avif, *.bmp, *.gif, *.heic, *.heif, *.jpeg, *.jpg, *.png, *.tiff, *.tif, *.webp"
  },
  "search.exclude": {
    "**/node_modules/**": true,
    "**/assets/lib/**": true
  },
  "[html]": {
    "editor.defaultFormatter": "gohugoio.gotmplfmt"
  },
}